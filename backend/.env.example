# Backend Environment Variables
# Copy this file to '.env' and adjust values for your environment.

# Port for the Node.js server to run on
PORT=5000

# MongoDB Connection String
# Get this from MongoDB Atlas (e.g., mongodb+srv://<username>:<password>@cluster.mongodb.net/workmitra)
MONGO_URI=mongodb://localhost:27017/workmitra

# Secret key for signing JSON Web Tokens
# Generate a strong random string (e.g., using `require('crypto').randomBytes(64).toString('hex')`)
JWT_SECRET=your_super_secret_jwt_key_here

# Google Gemini API Key for AI features (Matches, Recommendations, Chat Assistant)
# Get this from Google AI Studio
GEMINI_API_KEY=your_gemini_api_key_here

# CORS Origins (Comma-separated list of allowed frontend URLs)
# For local development: http://localhost:5173
# For production: https://workmitra.com,https://www.workmitra.com
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Razorpay API Keys
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
