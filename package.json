{
  "name": "freelance-react",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "render-build": "npm install --prefix backend && npm run build",
    "start": "node backend/server.js",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "NODE_ENV=test ACCESS_TOKEN_SECRET=test REFRESH_TOKEN_SECRET=test MONGO_URI=test ADMIN_EMAIL=test ADMIN_PASSWORD=test CORS_ORIGINS=test GEMINI_API_KEY=test FRONTEND_URL=test REDIS_URL=redis://localhost:6379 vitest run",
    "prepare": "husky"
  },
  "dependencies": {
    "@eslint/js": "^9.39.4",
    "@marsidev/react-turnstile": "^1.5.3",
    "@sentry/node": "^10.64.0",
    "@sentry/react": "^10.64.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "axios": "^1.18.1",
    "bullmq": "^5.79.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "framer-motion": "^12.42.2",
    "globals": "^17.4.0",
    "i18next": "^26.3.4",
    "i18next-browser-languagedetector": "^8.2.1",
    "ioredis": "^5.11.1",
    "lucide-react": "^1.23.0",
    "postcss": "^8.5.9",
    "posthog-js": "^1.399.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-helmet-async": "^3.0.0",
    "react-i18next": "^17.0.8",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.14.0",
    "recharts": "^3.9.1",
    "tailwindcss": "^3.4.19",
    "vite": "^8.0.4",
    "zustand": "^5.0.14"
  },
  "lint-staged": {
    "src/**/*.{js,jsx}": [
      "eslint --fix --max-warnings=0",
      "prettier --write"
    ],
    "backend/**/*.js": [
      "eslint --fix --max-warnings=0"
    ]
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "supertest": "^7.2.2",
    "vitest": "^4.1.10"
  }
}
